# Copy to .env.local for development.
#
# On Vercel, set these in:
#   Project → Settings → Environment Variables (Production / Preview / Dev).

# ───── Backend API URL ─────
# Where the FastAPI backend is reachable FROM THE BROWSER.
# Anything prefixed with NEXT_PUBLIC_ is bundled into client-side JS, so do
# NOT put secrets here.
#
# Local:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: set to your Render backend URL, e.g.
#   https://aptly-backend.onrender.com
