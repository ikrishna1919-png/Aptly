# Copy to .env and adjust as needed.
#
# These are the SAME variables expected in local dev (.env) and on Render
# (set in the dashboard — never commit secrets). See README "Deploy" for the
# full walkthrough.

# ───── Database ─────
# Local (matches infra/docker-compose.yml):
DATABASE_URL=postgresql+psycopg://aptly:aptly@localhost:5432/aptly
#
# Production (Neon): copy your Neon "Pooled connection" string and prefix the
# driver, e.g.
#   postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
# SQLAlchemy requires the `+psycopg` driver prefix; Neon's UI omits it.

# ───── CORS ─────
# Comma-separated list of allowed browser origins for the frontend.
# Local:
CORS_ORIGINS=http://localhost:3000
# Production: set to your Vercel URL, e.g. https://aptly.vercel.app
# (add the preview-deploy origin too if you want CORS to work on PR previews).

# ───── Environment label ─────
# development | staging | production
ENVIRONMENT=development

# ───── Rolling window (Phase 1) ─────
# Hours of freshness. Anything older is removed on every ingest pass.
HOURS_WINDOW=48

# ───── Admin token (Phase 1) ─────
# Shared secret required by POST /api/admin/ingest. Generate a long random
# string and set the SAME value on the GitHub Actions secret APTLY_ADMIN_TOKEN.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# ───── Anthropic API key (Phase 4) ─────
# Powers /api/tailor/{analyze,generate,docx}. Get one at
# https://console.anthropic.com/. Leave blank to run the tailoring endpoints
# in "demo mode" — they return deterministic mock data so the UI still works.
ANTHROPIC_API_KEY=
